---
import PageHero from "@components/common/PageHero.astro";
import Layout from "@/layouts/Layout.astro";
import "@/styles/animation/vt-content.css";
const { title, subtitle, description, ogImage } = Astro.props;
---

<Layout pageName={title} pageDescription={description} pageOgImage={ogImage}>
  <div
    class="fixed top-0 left-0 z-[-1] h-svh w-svw overflow-hidden opacity-20"
    aria-hidden="true"
  >
    <div
      class="sh-gradient-animate sh-gradient-0 absolute top-0 left-0 size-100"
      aria-hidden="true"
    >
    </div>
    <div
      class="sh-gradient-animate sh-gradient-1 absolute top-0 left-0 size-100"
      aria-hidden="true"
    >
    </div>
    <div
      class="sh-gradient-animate sh-gradient-2 absolute top-0 left-0 size-100"
      aria-hidden="true"
    >
    </div>
  </div>

  <div>
    <PageHero title={title} subtitle={subtitle} />
    <!-- <div class="h-16" aria-hidden="true"></div> -->
    <!-- 留白 -->
    <div
      id="sh-page_layout-content"
      class="relative mx-6 mb-10 w-auto lg:mx-auto lg:mt-20 lg:w-full lg:max-w-7xl lg:px-6"
    >
      <slot />
    </div>
  </div>
</Layout>

<script>
  import { gsap } from "gsap";

  document.addEventListener("DOMContentLoaded", () => {
    const gradients = document.querySelectorAll(".sh-gradient-animate");

    gradients.forEach((el) => {
      // 1. 初始隨機散落位置
      gsap.set(el, {
        x: "random(-20, 100)vw",
        y: "random(-20, 100)vh",
        scale: "random(1, 2)",
      });

      // 2. 定義一個「不斷尋找下一個隨機點」的函數
      function moveRandomly(target: Element) {
        gsap.to(target, {
          x: "random(-40, 120)vw", // 稍微超出螢幕，邊緣才不會穿幫
          y: "random(-40, 120)vh",
          scale: "random(1, 2.5)",
          duration: "random(5, 15)", // 移動時間拉長，速度會更優雅
          ease: "sine.inOut", // 兩點交接時會柔和地減速再加速

          // 核心：當這次移動完成時，再次呼叫自己，傳入下一個隨機點
          onComplete: () => moveRandomly(target),
        });
      }

      // 3. 啟動動畫
      moveRandomly(el);
    });
  });
</script>

<style>
  @media (min-width: 769px) {
    #sh-page_layout-content::after {
      position: fixed;
      top: 0;
      right: 0;
      width: 2.75rem;
      height: 100%;
      content: "";
      border-left: 1px solid #292524;
      background:
        repeating-linear-gradient(
          135deg,
          #0c0a09 0 0.5rem,
          #292524 0.5rem 0.75rem
        ),
        #0c0a09;
      z-index: -5;
    }

    #sh-page_layout-content::before {
      position: fixed;
      top: 0;
      left: 0;
      width: 2.75rem;
      height: 100%;
      content: "";
      border-right: 1px solid #292524;
      background:
        repeating-linear-gradient(
          135deg,
          #0c0a09 0 0.5rem,
          #292524 0.5rem 0.75rem
        ),
        #0c0a09;
      z-index: -5;
    }
  }

  #sh-page_layout-content {
    background-image: url("/assets/content_background.svg");
    /* 重複排列 */
    background-repeat: repeat;
    /* 置中 */
    background-position: center;
  }

  .sh-gradient-0 {
    background: #efef86;
    background: radial-gradient(
      circle,
      rgba(239, 239, 134, 1) 0%,
      rgba(239, 239, 134, 0) 60%
    );
  }

  .sh-gradient-1 {
    background: #86efac;
    background: radial-gradient(
      circle,
      rgba(134, 239, 172, 1) 0%,
      rgba(134, 239, 172, 0) 60%
    );
  }

  .sh-gradient-2 {
    background: #86edef;
    background: radial-gradient(
      circle,
      rgba(134, 237, 239, 1) 0%,
      rgba(134, 237, 239, 0) 60%
    );
  }
</style>
