---
import PageHero from "@components/common/PageHero.astro";
import Layout from "@/layouts/Layout.astro";
import "@/styles/animation/vt-content.css";
const { title, subtitle, description, ogImage } = Astro.props;
---

<Layout pageName={title} pageDescription={description} pageOgImage={ogImage}>
  <div
    class="fixed top-0 left-0 z-[-1] h-svh w-svw overflow-hidden opacity-20"
    aria-hidden="true"
  >
    <div
      class="sh-gradient-animate sh-gradient-0 absolute top-0 left-0 size-100"
      aria-hidden="true"
    >
    </div>
    <div
      class="sh-gradient-animate sh-gradient-1 absolute top-0 left-0 size-100"
      aria-hidden="true"
    >
    </div>
    <div
      class="sh-gradient-animate sh-gradient-2 absolute top-0 left-0 size-100"
      aria-hidden="true"
    >
    </div>
  </div>

  <div>
    <PageHero title={title} subtitle={subtitle} />
    <!-- <div class="h-16" aria-hidden="true"></div> -->
    <!-- 留白 -->
    <div
      id="sh-page_layout-content"
      class="relative mx-6 mb-10 w-auto lg:mx-auto lg:mt-20 lg:w-full lg:max-w-7xl lg:px-6"
    >
      <slot />
    </div>
  </div>
</Layout>

<script>
  import { gsap } from "gsap";

  const gradients = document.querySelectorAll(".sh-gradient-animate");

  // 儲存滑鼠座標與排斥半徑
  const mouse = { x: 0, y: 0 };
  const avoidRadius = 250; // 排斥圈半徑（像素），可以依需求調整
  const pushStrength = 60; // 被滑鼠彈開的力道

  // 監聽滑鼠移動
  window.addEventListener("mousemove", (e) => {
    mouse.x = e.clientX;
    mouse.y = e.clientY;
  });

  gradients.forEach((el) => {
    // 初始隨機位置
    gsap.set(el, {
      x: "random(-10, 90)vw",
      y: "random(-10, 90)vh",
      scale: "random(1, 2)",
    });

    function moveRandomly(target: Element) {
      gsap.to(target, {
        x: "random(-30, 110)vw",
        y: "random(-30, 110)vh",
        scale: "random(1, 2.5)",
        duration: "random(5, 10)",
        ease: "sine.inOut",
        overwrite: "auto", // 允許滑鼠干涉時蓋過這個動畫
        onComplete: () => moveRandomly(target),
      });
    }

    // 啟動漂流
    moveRandomly(el);

    // 檢查與滑鼠的距離
    gsap.ticker.add(() => {
      // 取得球目前的實際位置（相對於視窗）
      const rect = el.getBoundingClientRect();
      const ballX = rect.left + rect.width / 2;
      const ballY = rect.top + rect.height / 2;

      // 計算滑鼠與球中心的距離
      const dx = ballX - mouse.x;
      const dy = ballY - mouse.y;
      const distance = Math.sqrt(dx * dx + dy * dy);

      // 如果滑鼠靠近了排斥圈
      if (distance < avoidRadius && mouse.x !== 0) {
        // 計算排斥的方向與力道（越靠近推越遠）
        const force = (avoidRadius - distance) / avoidRadius;
        const pushX = (dx / distance) * force * pushStrength;
        const pushY = (dy / distance) * force * pushStrength;

        // 取得目前的 gsap 屬性值
        const currentX = gsap.getProperty(el, "x") as number;
        const currentY = gsap.getProperty(el, "y") as number;

        // 微調球的位置，產生被滑鼠「推開」的物理感
        gsap.to(el, {
          x: currentX + pushX,
          y: currentY + pushY,
          duration: 0.8,
          ease: "power2.out",
          overwrite: "auto",
          onComplete: () => {
            // 離開滑鼠範圍後，如果停下來了，就繼續原本的隨機漂流
            if (!gsap.isTweening(el)) {
              moveRandomly(el);
            }
          },
        });
      }
    });
  });
</script>

<style>
  @media (min-width: 769px) {
    #sh-page_layout-content::after {
      position: fixed;
      top: 0;
      right: 0;
      width: 2.75rem;
      height: 100%;
      content: "";
      border-left: 1px solid #292524;
      background:
        repeating-linear-gradient(
          135deg,
          #0c0a09 0 0.5rem,
          #292524 0.5rem 0.75rem
        ),
        #0c0a09;
      z-index: -5;
    }

    #sh-page_layout-content::before {
      position: fixed;
      top: 0;
      left: 0;
      width: 2.75rem;
      height: 100%;
      content: "";
      border-right: 1px solid #292524;
      background:
        repeating-linear-gradient(
          135deg,
          #0c0a09 0 0.5rem,
          #292524 0.5rem 0.75rem
        ),
        #0c0a09;
      z-index: -5;
    }
  }

  #sh-page_layout-content {
    background-image: url("/assets/content_background.svg");
    /* 重複排列 */
    background-repeat: repeat;
    /* 置中 */
    background-position: center;
  }

  .sh-gradient-0 {
    background: #efef86;
    background: radial-gradient(
      circle,
      rgba(239, 239, 134, 1) 0%,
      rgba(239, 239, 134, 0) 60%
    );
  }

  .sh-gradient-1 {
    background: #86efac;
    background: radial-gradient(
      circle,
      rgba(134, 239, 172, 1) 0%,
      rgba(134, 239, 172, 0) 60%
    );
  }

  .sh-gradient-2 {
    background: #86edef;
    background: radial-gradient(
      circle,
      rgba(134, 237, 239, 1) 0%,
      rgba(134, 237, 239, 0) 60%
    );
  }
</style>
