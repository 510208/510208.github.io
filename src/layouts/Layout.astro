---
import Footer from "@components/core/Footer.astro";
import HeaderBackground from "@components/core/HeaderBackground.astro";
import Header from "@components/core/Header.astro";
import MobileFloatMenu from "@components/core/MobileFloatMenu.astro";

import "@styles/global.css";

import ToTop from "@components/common/ToTop.astro";
import OgLayout from "./OgLayout.astro";

const baseUrl = Astro.site;
const { pageName, pageDescription, pageOgImage } = Astro.props;
const pagePath = new URL(Astro.request.url).pathname;

import { Font } from "astro:assets";
---

<!doctype html>
<html lang="zh-Hant" dir="ltr">
  <head>
    <script is:inline>
      //
      //          ██
      //        ████                                        █                         ██
      //      ██                                          ██                         ██
      //      ███         ██                     ███      ██      ██                ██   ██      ███
      //        ███    ███ ███     ██  ██  ████  ███   █████   ███ ███     ████     ██ ███      ██ ██   ██ ███
      //          ██  ██   ███    █████████████  ██████  ███  ██   ███    ██       █████       █████    ████
      //          ██  █████████   ████ ███  ██   ██      ██   ██ ██████  ██     ███████████     ██      ███
      //    █   ███   ████    ██ ███   ██   █   ██       ██   ████   ███ ████████   ██     █    ██████ ██
      //      ███                                         ██
      //
      //           ----   owo    S A M H A C K E R ' s   P E R S O N A L   W E B S I T E    owo   ----
      //
      //   * 你是電神！
      //   * 竟然被你發現了那我也沒必要躲起來了，去看看另一個可以用來藏神奇東西的地方吧
      //   * 提示：跟這裡一樣，都是寫前端的人一定天天在看的東西
      //
      //  喔對，這裡是 SamHacker 的個人網站，歡迎你來到這裡，請尊重智慧財產權，感謝你
      //
    </script>

    <meta charset="UTF-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0, maximum-scale=5.0"
    />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="icon" type="image/svg+xml" href="/favicon.png" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <meta
      http-equiv="Cache-Control"
      content="public, max-age=31536000, immutable"
    />
    <link rel="alternate" hreflang="x-default" href="https://samhacker.xyz/" />

    <link
      type="text/plain"
      rel="author"
      href={new URL("/humans.txt", baseUrl)}
    />

    <link rel="sitemap" href="/sitemap-index.xml" />

    <title>
      {pageName ? `${pageName} - SamHacker` : "SamHacker"}
    </title>

    <OgLayout
      pageName={pageName}
      pageDescription={pageDescription}
      pageOgImage={pageOgImage}
    />

    <!-- Astro View Transitions -->
    <!-- <ClientRouter /> -->

    <!-- Astro Font -->
    <Font cssVariable="--font-noto" />
    <Font cssVariable="--font-inter" />
    <Font cssVariable="--font-chenyuluoyan" />
    <Font cssVariable="--font-maple" />

    <!-- Google Tag Manager -->
    <script is:inline>
      (function (w, d, s, l, i) {
        w[l] = w[l] || [];
        w[l].push({ "gtm.start": new Date().getTime(), event: "gtm.js" });
        var f = d.getElementsByTagName(s)[0],
          j = d.createElement(s),
          dl = l != "dataLayer" ? "&l=" + l : "";
        j.async = true;
        j.src = "https://www.googletagmanager.com/gtm.js?id=" + i + dl;
        f.parentNode.insertBefore(j, f);
      })(window, document, "script", "dataLayer", "GTM-MTT9N2D9");
    </script>
    <!-- End Google Tag Manager -->
  </head>

  <body class="dark">
    <a
      href="#main-content"
      class="skip-link fixed top-4 left-4 z-100 px-10 py-5">跳至主要內容</a
    >

    <div id="kao-banner"></div>
    <script
      src="https://keepandroidopen.org/banner.js?lang=zh-tw&size=mini&id=kao-banner"
    ></script>

    <noscript>
      <h2 class="text-9xl text-red-600">
        你必須啟用 JavaScript 才能使用此網站。
      </h2>
      <br />
      <p>請啟用 JavaScript 後重新載入頁面。</p>
    </noscript>

    <HeaderBackground />
    <Header />
    <main id="main-content" tabindex="-1">
      <slot />
    </main>
    <MobileFloatMenu current={pagePath} />
    <Footer />

    <ToTop />

    <!-- Google Tag Manager (noscript) -->
    <noscript>
      <iframe
        src="https://www.googletagmanager.com/ns.html?id=GTM-MTT9N2D9"
        height="0"
        width="0"
        style="display:none;visibility:hidden"></iframe>
    </noscript>
    <!-- End Google Tag Manager (noscript) -->

    <script>
      import gsap from "gsap";

      // 取得 Loading 元素
      const getIndicator = () => document.getElementById("loading-indicator");

      // 1. 點擊連結，開始 SSR 抓取 (由下往上浮現)
      document.addEventListener("astro:before-preparation", () => {
        console.log("開始載入新頁面...");

        const el = getIndicator();
        console.log("取得指示器元素：", el);
        if (el) {
          el.classList.remove("hidden"); // 先顯示元素，讓它參與動畫

          gsap.to(el, {
            y: 0,
            opacity: 1,
            duration: 0.4,
            ease: "power2.out",
            overwrite: true, // 避免重複點擊時動畫衝突
          });
        }
      });

      // 2. 頁面內容載入並切換完成 (縮小或向下淡出)
      document.addEventListener("astro:page-load", () => {
        console.log("新頁面載入完成！");
        const el = getIndicator();
        console.log("取得指示器元素：", el);
        console.log(gsap);
        if (el) {
          gsap.to(el, {
            y: 10,
            opacity: 0,
            duration: 0.3,
            ease: "power2.in",
            delay: 0.2, // 稍微停留一下，避免快閃
          });

          el.classList.add("hidden"); // 動畫結束後隱藏元素，讓它不佔空間
        }
      });
    </script>
  </body>
</html>

<style>
  html,
  body {
    margin: 0;
    width: 100%;
    height: 100%;
  }

  .skip-link {
    position: absolute;
    top: -40px;
    left: 0;
    background-color: #fff;
    color: #000;
    padding: 8px;
    z-index: 100;
    text-decoration: none;
    font-size: 1.2rem;
  }

  .skip-link:focus {
    top: 0;
  }
</style>

<script is:inline>
  // 強制設定為深色主題
  document.documentElement.classList.add("dark");

  if (typeof localStorage !== "undefined") {
    localStorage.setItem("theme", "dark");
  }
</script>

<script>
  // 確保整個 DOM 樹和所有資源（如圖片、樣式）都載入完成後才觸發
  window.addEventListener("load", () => {
    // 利用 requestIdleCallback 告訴瀏覽器：「等你完全沒事忙了（閒置時），再執行這個」
    if ("requestIdleCallback" in window) {
      requestIdleCallback(() => {
        printEasterEgg();
      });
    } else {
      // 舊版瀏覽器不支援的替代方案，用最低限度的延遲執行
      setTimeout(printEasterEgg, 1);
    }
  });

  function printEasterEgg() {
    console.log(
      "%c捕獲野生電神！！",
      "color: #ff5e00; font-size: 20px; font-weight: bold; font-family: sans-serif; text-shadow: 2px 2px 0px rgba(0,0,0,0.1);",
    );
    console.log(
      "%c既然都打開 Console 了，不如來我的 GitHub 逛逛吧！ >> https://github.com/510208",
      "color: #fff; font-size: 14px;",
    );
  }
</script>
