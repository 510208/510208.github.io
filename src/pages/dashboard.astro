---
import { DashboardGrid } from "@components/page/Dashboard/DashboardGrid";
import PageLayout from "@/layouts/PageLayout.astro";

import "@styles/content.css";
---

<PageLayout
  title="儀表板"
  subtitle="數字可以解釋很多事情，有些數字甚至可以解釋一切"
  description="這裡是一些關於我的網站的數據儀表板，包含了訪問量、使用者來源、熱門文章等資訊。"
  ogImage="/assets/website_og/dashboard_og.png"
>
  <div
    class="mx-auto my-8 min-h-50 md:w-full md:max-w-2xl lg:max-w-5xl xl:max-w-6xl"
  >
    <DashboardGrid client:load />
  </div>
</PageLayout>
