---
import { Card } from "@/components/ui/card";
import PageLayout from "@/layouts/PageLayout.astro";

import { Image } from "astro:assets";
import LHLogo from "@/assets/pages/projects/logos/lighttp.svg";
import SHBNLogo from "@/assets/pages/projects/logos/shblog-next.svg";
import LHBg from "@/assets/pages/projects/thumbnails/lighttp.svg";
import SHBNBg from "@/assets/pages/projects/thumbnails/shblog-next.svg";

import "@styles/content.css";
---

<PageLayout
  title="專案"
  subtitle="我不是沒有失敗，只是沒有被失敗打敗而已"
  description="這是我做的一些開源專案，雖然還是不大成熟，但歡迎研究一下，可以提PR或Issue更好！"
  ogImage="/assets/website_og/projects_og.png"
>
  <div class="flex h-85 flex-col justify-between gap-4 lg:flex-row">
    <Card
      className="group sh-click-link relative w-1/2 cursor-pointer justify-center overflow-hidden py-13 pr-50 pl-[50px] transition-all duration-300 ease-in-out"
      id="sh-card-lighttp-bg"
      data-link="https://github.com/510208/lighttp"
    >
      <div
        class="absolute top-1/2 -right-1/3 -translate-y-1/2 transition-all duration-300 ease-in-out group-hover:right-[-20%]"
      >
        <Image alt="Lighttp Thumbnail" src={LHBg} class="object-cover" />
      </div>

      <div
        class="z-10 flex max-w-64 flex-col gap-[30px] transition-all duration-300 ease-in-out group-hover:gap-[40px]"
      >
        <Image alt="Lighttp Logo" src={LHLogo} />
        <p class="text-sky-100/90">
          LigHTTP是一款開源的HTTP請求工具，目的是成為Postman的輕量平替。希望可以提供極為簡單且高效的HTTP請求體驗。
        </p>
      </div>
    </Card>

    <Card
      className="group sh-click-link relative w-1/2 cursor-pointer justify-center overflow-hidden py-13 pr-50 pl-[50px] transition-all duration-300 ease-in-out"
      id="sh-card-shbn-bg"
      data-link="https://sh-blog-next.vercel.app/"
    >
      <div
        class="absolute top-1/2 -right-1/4 z-0 -translate-y-1/2 transition-all duration-300 ease-in-out group-hover:right-[-20%]"
      >
        <Image alt="SHBlog Next Thumbnail" src={SHBNBg} class="object-cover" />
      </div>

      <div
        class="z-10 flex max-w-64 flex-col gap-[30px] transition-all duration-300 ease-in-out group-hover:gap-[40px]"
      >
        <Image alt="SHBlog Next Logo" src={SHBNLogo} />
        <p class="text-emerald-100/90">
          SHBlog
          Next是一個基於Astro的個人部落格框架，目標是提供一個簡單、個性化、快速且開箱即用的個人開發者部落格解決方案。
        </p>
      </div>
    </Card>
  </div>
</PageLayout>

<style>
  #sh-card-lighttp-bg {
    background:
      linear-gradient(
        180deg,
        rgba(43, 47, 60, 0) 0%,
        rgba(43, 47, 60, 0.8) 100%
      ),
      #272728;

    &:hover {
      background:
        linear-gradient(
          180deg,
          rgba(56, 61, 77, 0) 0%,
          rgba(56, 61, 77, 0.8) 100%
        ),
        #393949;
    }
  }

  #sh-card-shbn-bg {
    background:
      linear-gradient(
        180deg,
        rgba(45, 77, 55, 0) 0%,
        rgba(45, 77, 55, 0.8) 100%
      ),
      #1b241e;

    &:hover {
      background:
        linear-gradient(
          180deg,
          rgba(58, 93, 69, 0) 0%,
          rgba(58, 93, 69, 0.9) 100%
        ),
        #263a2c;
    }
  }
</style>

<script>
  // 點擊卡片時打開對應的GitHub頁面
  document.addEventListener("DOMContentLoaded", () => {
    const cards = document.querySelectorAll(".sh-click-link");
    cards.forEach((card) => {
      card.addEventListener("click", () => {
        const link = card.getAttribute("data-link");
        if (link) {
          window.open(link, "_blank");
        }
      });
    });
  });
</script>
