---
import config from "@shConfig";
import { Button } from "@ui/button.tsx";
import { Mail, Info } from "lucide-react";

const links = config.navBar.links;
---

<header
  class="fixed top-4.5 left-1/2 z-50 w-full max-w-[1278px] -translate-x-1/2 px-4 lg:px-0"
  transition:name="header"
>
  <!-- 背景模糊裝飾 -->
  <div
    class="absolute inset-0 -z-10 rounded-lg bg-stone-900/10 opacity-100 backdrop-blur-[6px]"
    aria-hidden="true"
  >
  </div>

  <!-- 主標頭 -->
  <nav
    class="flex h-14 items-center justify-between rounded-lg border border-white/10 bg-neutral-900/50 px-2.5"
  >
    <!-- Logo and Site Title -->
    <div class="flex items-center gap-2">
      <div class="h-9 w-9 overflow-hidden rounded-lg">
        <img
          src="/favicon.png"
          alt="SamHacker"
          class="h-full w-full object-cover"
        />
      </div>
      <a class="hidden lg:block" href="/">
        <h1 class="font-funny text-3xl leading-none text-white capitalize">
          SamHacker
        </h1>
      </a>
    </div>

    <!-- Navigation Links -->
    <div class="flex items-center gap-2 lg:gap-4">
      <!-- Main Nav -->
      <div class="hidden items-center gap-1 pr-4 lg:flex">
        {
          links.map((link, index) => (
            <div class="flex items-center">
              <a
                href={link.href}
                class="flex h-6 items-center px-2 text-sm font-medium text-white uppercase transition-colors hover:text-white/80 lg:px-4"
              >
                {link.title}
              </a>
              {index < links.length - 1 && (
                <span class="text-sm text-neutral-400">/</span>
              )}
            </div>
          ))
        }
      </div>

      <div class="flex items-center gap-1 lg:hidden">
        {
          links.map((link, index) => (
            <div class="flex items-center">
              <a
                href={link.href}
                class="flex h-6 items-center px-2 text-sm font-medium text-white uppercase transition-colors hover:text-white/80"
                aria-label={link.title}
              >
                <link.icon size={16} />
              </a>
              {index < links.length - 1 && (
                <span class="hidden text-sm text-neutral-400 sm:block">/</span>
              )}
            </div>
          ))
        }
      </div>

      <!-- Action Buttons -->
      <div class="hidden items-center gap-2 md:flex">
        <a
          href="mailto:xux510208@gmail.com"
          target="_blank"
          rel="noopener noreferrer"
        >
          <Button
            client:load
            variant="ghost"
            size="icon"
            className="hidden items-center justify-center rounded-lg hover:bg-white/5 sm:flex"
            aria-label="Contact"
          >
            <Mail size={18} />
          </Button>
        </a>

        <a href="/about" target="_blank" rel="noopener noreferrer">
          <Button
            client:load
            variant="ghost"
            size="icon"
            className="hidden items-center justify-center rounded-lg hover:bg-white/5 sm:flex"
            aria-label="Info"
          >
            <Info size={18} />
          </Button>
        </a>
      </div>
    </div>
  </nav>
</header>
