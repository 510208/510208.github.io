---

<div
  class="welcome-animation fixed top-0 left-0 z-999 flex h-screen w-screen items-center justify-center bg-stone-900"
>
  <div class="welcome-animation__content">
    <h1>Welcome to My Portfolio</h1>
    <p>Discover my projects and skills</p>
  </div>
</div>

<script>
  import { gsap } from "gsap";

  declare global {
    interface Window {
      __welcomeFinished?: boolean;
    }
  }

  document.addEventListener("DOMContentLoaded", () => {
    const animation = document.querySelector(".welcome-animation");
    if (!animation) return;

    const tl = gsap.timeline();
    tl.delay(2);

    tl.to(animation, { opacity: 1, duration: 1 }).to(animation, {
      opacity: 0,
      duration: 1,
    });

    tl.eventCallback("onComplete", () => {
      (animation as HTMLElement).style.display = "none";
      (animation as HTMLElement).style.opacity = "1";

      // 📢 關鍵改動：發送事件前，先在 window 掛上旗標（Flag）
      window.__welcomeFinished = true;

      // 發送自定義事件
      window.dispatchEvent(new CustomEvent("welcomeFinished"));
    });
  });
</script>
