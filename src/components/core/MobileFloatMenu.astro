---
import config from "@shConfig";
import { Separator } from "@/components/ui/separator";
import { ChevronUp } from "@lucide/astro";

const links = config.navBar.links;

interface Props {
  /** 當前頁面路徑 */
  current: string;
}

const { current } = Astro.props;
---

<!-- 浮動選單 -->
<div class="sh-bg-gradient fixed bottom-0 left-0 z-50 min-h-25 w-dvw lg:hidden">
  <div
    id="sh-mobile-navbar-container"
    class="sh-bg-shadow absolute bottom-10 left-1/2 flex -translate-x-1/2 items-center justify-center gap-3 rounded-xl border border-stone-700/50 bg-stone-700/40 px-2.5 py-1.5 backdrop-blur"
  >
    <nav
      class="flex items-center gap-3"
      tabindex="0"
      id="sh-mobile-navbar"
      aria-label="手機版選單"
      data-state="collapsed"
    >
      {
        links.map((link) => {
          const isActive = current === link.href;
          if (link.href === current) {
            return (
              <>
                {/* 未展開 */}
                <div
                  aria-label={`${link.title} 頁面`}
                  aria-current="page"
                  data-activated="true"
                  class="sh-text-primary sh-text-sm sh-font-medium flex items-center justify-center p-1"
                  id={`sh-mobile-navbar-${link.title.toLowerCase().replace(/\s+/g, "-")}`}
                >
                  <link.icon size={20} className="text-neutral-100" />
                </div>

                {/* 展開 */}
                <div
                  aria-label={`${link.title} 頁面`}
                  aria-current="page"
                  data-activated="false"
                  class="sh-text-primary sh-text-sm sh-font-medium items-center justify-center gap-2.5 rounded-sm bg-stone-100 px-2.5 py-1.5 data-[activated=false]:hidden data-[activated=true]:flex"
                  id={`sh-mobile-navbar-${link.title.toLowerCase().replace(/\s+/g, "-")}-expanded`}
                >
                  <link.icon size={22} className="text-stone-950" />
                  <div class="flex flex-col items-start justify-center">
                    <span class="text-sm font-medium text-stone-900">
                      {link.alt}
                    </span>
                    <span class="text-xs font-normal text-stone-700">
                      {link.title}
                    </span>
                  </div>
                </div>
              </>
            );
          } else {
            return (
              <a
                href={link.href}
                target={link.href.startsWith("http") ? "_blank" : "_self"}
                rel={
                  link.href.startsWith("http")
                    ? "noopener noreferrer"
                    : undefined
                }
                aria-label={`${link.title} 頁面`}
                class={`sh-text-white sh-text-sm sh-font-medium sh-transition-colors sh-duration-300 sh-ease-in-out ${isActive ? "sh-text-primary" : "hover:sh-text-primary"} p-1`}
                id={`sh-mobile-navbar-${link.title.toLowerCase().replace(/\s+/g, "-")}`}
              >
                <link.icon size={20} className="text-neutral-400" />
              </a>
            );
          }
        })
      }
    </nav>

    <Separator orientation="vertical" />

    <ChevronUp
      size={16}
      id="sh-mobile-navbar-chevron"
      class="text-neutral-400"
    />
  </div>
</div>

<style>
  /* 浮動選單背景漸層 */
  .sh-bg-gradient {
    background: linear-gradient(
      180deg,
      rgba(0, 0, 0, 0) 20%,
      rgba(0, 0, 0, 0.6) 100%
    );
  }

  /* 浮動選單陰影 */
  .sh-bg-shadow {
    box-shadow: 0 4px 20px -6px rgba(255, 255, 255, 0.2);
  }
</style>

<script>
  import gsap from "gsap";

  document.addEventListener("DOMContentLoaded", () => {
    const container = document.querySelector(
      "#sh-mobile-navbar-container",
    ) as HTMLElement | null;
    const nav = document.querySelector(
      "#sh-mobile-navbar",
    ) as HTMLElement | null;
    const chevron = document.querySelector(
      "#sh-mobile-navbar-chevron",
    ) as HTMLElement | null;

    // 這兩個改為「選配」元素
    const collapsedItem = document.querySelector(
      "[data-activated]",
    ) as HTMLElement | null;
    const expandedItem = document.querySelector(
      "[data-activated]",
    ) as HTMLElement | null;

    // 預檢查：只要核心的容器和箭頭在，動畫就可以初始化
    if (!container || !nav || !chevron) {
      console.warn("未找到核心選單元素或切換按鈕，無法初始化導航列功能。");
      return;
    }

    // 初始狀態
    gsap.set(chevron, { rotate: 0, transformOrigin: "50% 50%" });
    container.setAttribute("aria-expanded", "false");

    let isAnimating = false;

    const expand = () => {
      if (isAnimating || nav.dataset.state === "expanded") return;
      isAnimating = true;

      const startWidth = container.getBoundingClientRect().width;
      const startHeight = container.getBoundingClientRect().height;

      nav.setAttribute("data-state", "expanded");
      container.setAttribute("aria-expanded", "true");

      // 安全設定屬性與初始動畫狀態
      if (collapsedItem) {
        collapsedItem.setAttribute("data-activated", "false");
        gsap.set(collapsedItem, { position: "absolute", opacity: 1 });
      }
      if (expandedItem) {
        expandedItem.setAttribute("data-activated", "true");
        gsap.set(expandedItem, { display: "flex", opacity: 0, scale: 0.85 });
      }

      // 先切換顯示後，量測展開後的目標寬度
      const endWidth = container.getBoundingClientRect().width;
      const endHeight = container.getBoundingClientRect().height;
      gsap.set(container, { width: startWidth, height: startHeight });

      // 建立時間軸
      const tl = gsap.timeline({
        onComplete: () => {
          if (collapsedItem) {
            gsap.set(collapsedItem, { position: "static", display: "none" });
          }
          gsap.set(container, { height: "auto" });
          isAnimating = false;
        },
      });

      // 基礎動畫：箭頭與容器（不管有沒有 item 都會執行）
      tl.to(
        chevron,
        { rotate: 180, duration: 0.4, ease: "power2.inOut" },
        0,
      ).to(
        container,
        {
          width: endWidth,
          height: endHeight,
          borderRadius: 12,
          duration: 0.4,
          ease: "power3.inOut",
        },
        0,
      );

      // 條件式動畫：只有元素存在時才塞入時間軸
      if (collapsedItem) {
        tl.to(
          collapsedItem,
          { opacity: 0, duration: 0.2, ease: "power2.in" },
          0,
        );
      }
      if (expandedItem) {
        tl.to(
          expandedItem,
          { opacity: 1, scale: 1, duration: 0.35, ease: "back.out(1.6)" },
          0.1,
        );
      }

      // 最後補上寬度自適應
      tl.set(container, { width: "auto" });
    };

    const collapse = () => {
      if (isAnimating || nav.dataset.state === "collapsed") return;
      isAnimating = true;

      const startWidth = container.getBoundingClientRect().width;
      const startHeight = container.getBoundingClientRect().height;

      nav.setAttribute("data-state", "collapsed");
      container.setAttribute("aria-expanded", "false");

      if (collapsedItem) {
        gsap.set(collapsedItem, {
          display: "flex",
          position: "absolute",
          opacity: 0,
          scale: 0.85,
        });
      }

      const endWidth = container.getBoundingClientRect().width;
      const endHeight = container.getBoundingClientRect().height;
      gsap.set(container, { width: startWidth, height: startHeight });

      const tl = gsap.timeline({
        onComplete: () => {
          if (collapsedItem) {
            collapsedItem.setAttribute("data-activated", "true");
            gsap.set(collapsedItem, { position: "static" });
          }
          if (expandedItem) {
            expandedItem.setAttribute("data-activated", "false");
            gsap.set(expandedItem, { display: "none" });
          }
          gsap.set(container, { width: "auto", height: "auto" });
          isAnimating = false;
        },
      });

      // 基礎動畫
      tl.to(chevron, { rotate: 0, duration: 0.4, ease: "power2.inOut" }, 0).to(
        container,
        {
          width: endWidth,
          height: endHeight,
          borderRadius: 9999,
          duration: 0.4,
          ease: "power3.inOut",
        },
        0,
      );

      // 條件式動畫
      if (expandedItem) {
        tl.to(
          expandedItem,
          { opacity: 0, scale: 0.85, duration: 0.25, ease: "power2.in" },
          0,
        );
      }
      if (collapsedItem) {
        tl.to(
          collapsedItem,
          { opacity: 1, scale: 1, duration: 0.3, ease: "back.out(1.6)" },
          0.1,
        );
      }
    };

    container.addEventListener("click", (e) => {
      e.stopPropagation();
      nav.dataset.state === "expanded" ? collapse() : expand();
    });

    document.addEventListener("click", (e) => {
      if (
        nav.dataset.state === "expanded" &&
        !container.contains(e.target as Node)
      ) {
        collapse();
      }
    });
  });
</script>
