---
import config from "@shConfig";
import { Separator } from "@/components/ui/separator";
import { ChevronUp } from "@lucide/astro";

const links = config.navBar.links;

interface Props {
  /** 當前頁面路徑 */
  current: string;
}

const { current } = Astro.props;
---

<!-- 浮動選單 -->
<div
  class="sh-bg-gradient fixed bottom-0 left-0 z-50 min-h-25 w-dvw lg:hidden max-height-too-small:static max-height-too-small:min-h-0"
>
  <div
    id="sh-mobile-navbar-container"
    class="sh-bg-shadow absolute bottom-10 left-1/2 flex -translate-x-1/2 items-center justify-center gap-3 rounded-xl border border-stone-700/50 bg-stone-700/40 px-2.5 py-1.5 backdrop-blur max-height-too-small:static max-height-too-small:mx-auto max-height-too-small:my-4 max-height-too-small:translate-x-0"
  >
    <nav
      class="flex items-center gap-3"
      tabindex="0"
      id="sh-mobile-navbar"
      aria-label="手機版選單"
      data-state="collapsed"
    >
      {
        links.map((link) => {
          const isActive = current === link.href;
          if (link.href === current) {
            return (
              <>
                {/* 未展開版 - 將 data-actived 修正為 data-activated */}
                <div
                  aria-label={`${link.title} 頁面`}
                  aria-current="page"
                  data-activated="true"
                  class="sh-text-primary sh-text-sm sh-font-medium flex items-center justify-center p-1"
                  id={`sh-mobile-navbar-${link.title.toLowerCase().replace(/\s+/g, "-")}`}
                >
                  <link.icon size={20} className="text-neutral-100" />
                </div>

                {/* 展開版 - 移除會干擾 Flip 外掛量測的 data-[activated] Tailwind 隱藏類別 */}
                <div
                  aria-label={`${link.title} 頁面`}
                  aria-current="page"
                  data-activated="false"
                  class="sh-text-primary sh-text-sm sh-font-medium hidden items-center justify-center gap-2.5 rounded-sm bg-stone-100 px-2.5 py-1.5"
                  id={`sh-mobile-navbar-${link.title.toLowerCase().replace(/\s+/g, "-")}-expanded`}
                >
                  <link.icon size={22} className="text-stone-950" />
                  <div class="flex flex-col items-start justify-center">
                    <span class="text-sm font-medium text-stone-900">
                      {link.alt}
                    </span>
                    <span class="text-xs font-normal text-stone-700">
                      {link.title}
                    </span>
                  </div>
                </div>
              </>
            );
          } else {
            return (
              <a
                href={link.href}
                target={link.href.startsWith("http") ? "_blank" : "_self"}
                rel={
                  link.href.startsWith("http")
                    ? "noopener noreferrer"
                    : undefined
                }
                aria-label={`${link.title} 頁面`}
                class={`sh-text-white sh-text-sm sh-font-medium sh-transition-colors sh-duration-300 sh-ease-in-out ${isActive ? "sh-text-primary" : "hover:sh-text-primary"} p-1`}
                id={`sh-mobile-navbar-${link.title.toLowerCase().replace(/\s+/g, "-")}`}
              >
                <link.icon size={20} className="text-neutral-400" />
                <p class="sr-only">{link.title}</p>
              </a>
            );
          }
        })
      }
    </nav>

    <Separator orientation="vertical" />

    <ChevronUp
      size={16}
      id="sh-mobile-navbar-chevron"
      class="text-neutral-400"
    />
  </div>
</div>

<style>
  /* 浮動選單背景漸層 */
  .sh-bg-gradient {
    background: linear-gradient(
      180deg,
      rgba(0, 0, 0, 0) 20%,
      rgba(0, 0, 0, 0.6) 100%
    );
  }

  /* 浮動選單陰影 */
  .sh-bg-shadow {
    box-shadow: 0 4px 20px -6px rgba(255, 255, 255, 0.2);
  }
</style>

<script>
  import gsap from "gsap";
  import { Flip } from "gsap/Flip";
  gsap.registerPlugin(Flip);

  document.addEventListener("DOMContentLoaded", () => {
    const container = document.querySelector(
      "#sh-mobile-navbar-container",
    ) as HTMLElement | null;
    const nav = document.querySelector(
      "#sh-mobile-navbar",
    ) as HTMLElement | null;
    const chevron = document.querySelector(
      "#sh-mobile-navbar-chevron",
    ) as HTMLElement | null;

    const collapsedItem = document.querySelector(
      '[data-activated="true"]',
    ) as HTMLElement | null;
    const expandedItem = document.querySelector(
      '[data-activated="false"]',
    ) as HTMLElement | null;

    if (!container || !nav || !chevron) {
      console.warn("未找到核心選單元素或切換按鈕，無法初始化導航列功能。");
      return;
    }

    // A11y：確保鍵盤使用者能點選容器
    if (!container.getAttribute("role"))
      container.setAttribute("role", "button");
    if (!container.getAttribute("tabindex"))
      container.setAttribute("tabindex", "0");
    container.setAttribute("aria-expanded", "false");

    // 初始狀態
    gsap.set(chevron, { rotate: 0, transformOrigin: "50% 50%" });
    gsap.set([container, chevron], { willChange: "transform, opacity" });

    let isAnimating = false;
    const prefersReducedMotion = window.matchMedia(
      "(prefers-reduced-motion: reduce)",
    ).matches;

    const toggleNavbar = (shouldExpand: boolean) => {
      if (isAnimating) return;

      const targetState = shouldExpand ? "expanded" : "collapsed";
      if (nav.dataset.state === targetState) return;

      // 無障礙支援：如果使用者開啟「減少動態效果」，直接切換
      if (prefersReducedMotion) {
        nav.setAttribute("data-state", targetState);
        container.setAttribute(
          "aria-expanded",
          shouldExpand ? "true" : "false",
        );
        if (collapsedItem) {
          collapsedItem.setAttribute(
            "data-activated",
            shouldExpand ? "false" : "true",
          );
          collapsedItem.style.display = shouldExpand ? "none" : "flex";
        }
        if (expandedItem) {
          expandedItem.setAttribute(
            "data-activated",
            shouldExpand ? "true" : "false",
          );
          expandedItem.style.display = shouldExpand ? "flex" : "none";
        }
        gsap.set(chevron, { rotate: shouldExpand ? 180 : 0 });
        return;
      }

      isAnimating = true;

      // 記錄變化前的容器狀態
      const state = Flip.getState(container, { props: "borderRadius" });

      // 瞬間切換 DOM 狀態
      nav.setAttribute("data-state", targetState);
      container.setAttribute("aria-expanded", shouldExpand ? "true" : "false");

      if (shouldExpand) {
        container.style.borderRadius = "12px";

        // 將舊元素設為絕對定位，使其不佔據空間，並保持可見以便進行淡出
        if (collapsedItem) {
          collapsedItem.setAttribute("data-activated", "false");
          gsap.set(collapsedItem, { position: "absolute", opacity: 1 });
        }
        if (expandedItem) {
          expandedItem.setAttribute("data-activated", "true");
          // 新元素設為靜態定位，讓容器能正確計算出「只包含新元素」的真實終點寬高
          gsap.set(expandedItem, {
            display: "flex",
            position: "static",
            opacity: 0,
            scale: 0.85,
          });
        }
      } else {
        container.style.borderRadius = "9999px";

        // 反過來，收合時將展開的元素設為絕對定位
        if (expandedItem) {
          expandedItem.setAttribute("data-activated", "false");
          gsap.set(expandedItem, { position: "absolute", opacity: 1 });
        }
        if (collapsedItem) {
          collapsedItem.setAttribute("data-activated", "true");
          gsap.set(collapsedItem, {
            display: "flex",
            position: "static",
            opacity: 0,
            scale: 0.85,
          });
        }
      }

      // 調用 GPU 縮放動畫
      Flip.from(state, {
        duration: 0.35,
        ease: "power2.inOut",
        scale: true,
        onComplete: () => {
          // 動態結束後，把舊元素徹底隱藏，並恢復定位狀態以利下次量測
          if (shouldExpand) {
            if (collapsedItem)
              gsap.set(collapsedItem, { display: "none", position: "static" });
          } else {
            if (expandedItem)
              gsap.set(expandedItem, { display: "none", position: "static" });
          }
          isAnimating = false;
        },
      });

      // 文字內容的淡入與箭頭旋轉動畫
      const tl = gsap.timeline();
      tl.to(
        chevron,
        {
          rotate: shouldExpand ? 180 : 0,
          duration: 0.35,
          ease: "power2.inOut",
        },
        0,
      );

      if (shouldExpand) {
        if (collapsedItem)
          tl.to(collapsedItem, { opacity: 0, duration: 0.15 }, 0); // 舊的淡出
        if (expandedItem)
          tl.to(
            expandedItem,
            { opacity: 1, scale: 1, duration: 0.25, ease: "back.out(1.5)" },
            0.1,
          ); // 新的淡入
      } else {
        if (expandedItem)
          tl.to(expandedItem, { opacity: 0, duration: 0.15 }, 0); // 舊的淡出
        if (collapsedItem)
          tl.to(
            collapsedItem,
            { opacity: 1, scale: 1, duration: 0.25, ease: "back.out(1.5)" },
            0.1,
          ); // 新的淡入
      }
    };

    const expand = () => toggleNavbar(true);
    const collapse = () => toggleNavbar(false);

    // 點擊事件
    container.addEventListener("click", (e) => {
      e.stopPropagation();
      nav.dataset.state === "expanded" ? collapse() : expand();
    });

    document.addEventListener("click", (e) => {
      if (
        nav.dataset.state === "expanded" &&
        !container.contains(e.target as Node)
      ) {
        collapse();
      }
    });
  });
</script>
