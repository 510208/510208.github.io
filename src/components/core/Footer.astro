---
import config from "@shConfig";
import { Separator } from "@ui/separator";
import { Image } from "astro:assets";

import backgroundImage from "@/assets/core/footer_bg.png";
---

<footer
  class="relative min-h-100 w-full border-t-1 border-stone-800 bg-stone-950 px-6 pt-4 font-mono lg:px-8"
  transition:name="footer"
>
  <!-- 背景圖 -->
  <Image
    src={backgroundImage}
    alt=""
    class="pointer-events-none absolute top-0 left-0 h-full w-full object-cover object-top opacity-30 select-none"
  />

  <div class="mx-auto max-w-7xl py-12">
    <div>
      <div class="flex justify-between gap-10">
        <div class="mb-4 overflow-hidden lg:mb-10">
          <h2
            class="mb-10 bg-gradient-to-br from-stone-400 to-stone-300 bg-clip-text font-mono text-6xl font-bold text-transparent uppercase"
          >
            SamHacker Dev.
          </h2>
          <p class="hidden max-w-sm text-stone-300 md:block">
            Hi there!
            <br />
            I'm SamHacker, a passionate developer dedicated to crafting innovative
            solutions and sharing knowledge with the community.
            <br />
            Feel free to explore my projects and get in touch!
          </p>
        </div>

        <div class="mb-10 hidden gap-8 md:flex">
          <!-- 導航 -->
          <div class="w-50">
            <h3 class="text-xl font-semibold">本站連結</h3>
            <Separator className="mb-4" />
            <div class="flex flex-col gap-2">
              {
                config.navBar.links.map((link) => (
                  <a
                    href={link.href}
                    class="flex items-center gap-2 text-gray-400 transition-colors hover:text-white"
                  >
                    <link.icon size={16} class="mr-2" />
                    {link.title}
                  </a>
                ))
              }
            </div>
          </div>

          <!-- 聯絡方式 -->
          <div class="hidden w-50 xl:block">
            <h3 class="text-xl font-semibold">聯絡我</h3>
            <Separator className="mb-4" />
            <div
              class="grid w-fit grid-cols-1 gap-3 md:grid-cols-2 lg:grid-cols-4"
            >
              {
                config.socialLinks.map((link) => (
                  <a
                    href={link.href}
                    class="flex items-center gap-2 text-gray-400 transition-colors hover:text-white"
                  >
                    <link.icon size={22} />
                  </a>
                ))
              }
            </div>
          </div>
        </div>
      </div>

      <Separator className="mb-10" />

      <div class="flex flex-col items-center justify-between gap-6 md:flex-row">
        <p class="text-sm text-gray-400">
          &copy; <span id="sh-footer-year">2025</span> SamHacker. All rights reserved.
        </p>
        <div class="flex items-center gap-4">
          {
            config.socialLinks.slice(0, 6).map((link, index) => (
              <a
                href={link.href}
                target="_blank"
                rel="noopener noreferrer"
                class="text-gray-400 transition-colors hover:text-white"
                aria-label={link.title}
              >
                <link.icon class="h-6 w-6" />
              </a>
            ))
          }
        </div>
      </div>
    </div>

    <script>
      document.addEventListener("DOMContentLoaded", () => {
        const yearSpan = document.getElementById("sh-footer-year");
        if (yearSpan) {
          const currentYear = new Date().getFullYear();
          yearSpan.textContent = currentYear.toString();
          console.log("Footer year updated to:", currentYear);
        }
      });
    </script>
  </div>
</footer>
