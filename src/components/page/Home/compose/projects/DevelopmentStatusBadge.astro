---
import type { Project } from "@/types/shsite.projects";

interface Props {
  status: Project["status"];
}

const { status } = Astro.props;
const STATUS_PROCESSED = status ?? "on-going";

let badgeClass = "";
let statusText = "";

switch (STATUS_PROCESSED) {
  case "on-going":
    badgeClass = "border-green-300 bg-green-200/20 text-green-100";
    statusText = "維護中";
    break;
  case "paused":
    badgeClass = "border-orange-300 bg-orange-200/20 text-orange-100";
    statusText = "暫停開發";
    break;
  case "eol":
    badgeClass = "border-gray-300 bg-gray-200/20 text-gray-100";
    statusText = "已終止維護 (EOL)";
    break;
  case "archived":
    badgeClass = "border-yellow-300 bg-yellow-200/20 text-yellow-100";
    statusText = "已封存";
    break;
  case "completed":
    badgeClass = "border-green-800 bg-green-200/20 text-green-600";
    statusText = "已完成";
    break;
}
---

<span
  class={`inline-flex items-center rounded-md border px-2.5 py-0.5 text-xs font-semibold transition-colors focus:outline-none focus:ring-2 focus:ring-ring focus:ring-offset-2 ${badgeClass}`}
>
  {statusText}
</span>
