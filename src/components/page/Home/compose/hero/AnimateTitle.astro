---
interface Props {
  textOutside?: string;
  textInside?: string;
  radius?: number;
  bgColor?: string; // 新增：允許外部決定背景色，用於精準遮罩
}

const {
  textOutside = "SamHacker",
  textInside = "御坂糸紗奈",
  radius = 150,
  bgColor = "#111111", // 預設為原本的深色背景
} = Astro.props;
---

<div
  class="sh-text-mask-block pointer-events-none relative h-fit w-full cursor-none touch-pan-y overflow-hidden select-none"
  id="textContainer"
  data-radius={radius}
  aria-hidden="true"
>
  <div
    class="sh-text-layer sh-layer-outside relative top-0 left-0 z-[1] flex w-full items-center justify-center overflow-hidden py-10 select-none"
  >
    <span
      class="sh-split-target sh-text-stroke font-inter m-0 text-[128px] leading-none font-black tracking-[2px] text-nowrap text-transparent uppercase md:text-[300px]"
    >
      {textOutside}
    </span>
  </div>

  <div
    class="sh-text-layer sh-layer-inside pointer-events-none absolute inset-0 z-[2] flex w-full items-center justify-center overflow-hidden select-none"
    style={`background-color: ${bgColor};`}
  >
    <span
      class="sh-split-target m-0 text-[128px] leading-none font-black tracking-[2px] text-nowrap text-stone-200/60 uppercase md:text-[250px]"
    >
      {textInside}
    </span>
  </div>

  <div
    class="sh-pointer-dot pointer-events-none absolute top-0 left-0 z-[3] h-2 w-2 rounded-full bg-black"
    id="pointerDot"
  >
  </div>

  <div
    class="sh-gradient-overlay pointer-events-none absolute inset-0 z-4 h-full w-full"
  >
  </div>
</div>

<style>
  .sh-layer-inside {
    clip-path: circle(0px at 0px 0px);
  }

  .sh-pointer-dot {
    transform: translate(-50%, -50%) scale(0);
  }

  .sh-text-stroke {
    -webkit-text-stroke: 4px #99999920;
  }

  .sh-gradient-overlay {
    -webkit-backdrop-filter: opacity(var(--sh-mask-opacity, 1));
    backdrop-filter: opacity(var(--sh-mask-opacity, 1));

    -webkit-mask-image: linear-gradient(
      to bottom,
      rgba(0, 0, 0, 0) 0%,
      rgba(0, 0, 0, 0.6) 100%
    );
    mask-image: linear-gradient(
      to bottom,
      rgba(0, 0, 0, 0) 0%,
      rgba(0, 0, 0, 0.6) 100%
    );
  }
</style>

<script>
  import gsap from "gsap";
  import SplitText from "gsap/SplitText";

  gsap.registerPlugin(SplitText);

  const container = document.getElementById("textContainer");
  const insideLayer = document.querySelector(".sh-layer-inside");
  const pointerDot = document.getElementById("pointerDot");
  console.log("AnimateTitle mounted:", { container, insideLayer, pointerDot });

  const splitOutside = new SplitText(".sh-layer-outside .sh-split-target", {
    type: "chars",
  });
  const splitInside = new SplitText(".sh-layer-inside .sh-split-target", {
    type: "chars",
  });

  function initHeroAnimations() {
    gsap.set([splitOutside.chars, splitInside.chars], { x: 100, opacity: 0 });
  }

  function playHeroAnimations() {
    if (container && insideLayer && pointerDot) {
      const circleRadius = parseInt(
        container.getAttribute("data-radius") || "150",
        10,
      );

      const introTimeline = gsap.timeline({
        onComplete: initializePointerTracking,
      });

      introTimeline.to([splitOutside.chars, splitInside.chars], {
        x: 0,
        opacity: 1,
        duration: 0.8,
        ease: "power3.out",
        stagger: 0.05,
      });

      function initializePointerTracking() {
        const maskSettings = { x: 0, y: 0, radius: 0 };
        let isInsideContainer = false; // 追蹤滑鼠是否進入了文字容器的垂直範圍內

        function updateClipPath() {
          gsap.set(insideLayer, {
            clipPath: `circle(${maskSettings.radius}px at ${maskSettings.x}px ${maskSettings.y}px)`,
          });
          gsap.set(pointerDot, {
            x: maskSettings.x,
            y: maskSettings.y,
          });
        }

        const xTo = gsap.quickTo(maskSettings, "x", {
          duration: 0.4,
          ease: "power3.out",
          onUpdate: updateClipPath,
        });
        const yTo = gsap.quickTo(maskSettings, "y", {
          duration: 0.4,
          ease: "power3.out",
          onUpdate: updateClipPath,
        });
        const radiusTo = gsap.quickTo(maskSettings, "radius", {
          duration: 0.3,
          ease: "power2.out",
          onUpdate: updateClipPath,
        });

        // 核心修改：從 window 層級捕捉全局滑鼠座標，並轉換為容器相對座標
        function handleGlobalPointerMove(e: PointerEvent) {
          const rect = container!.getBoundingClientRect();

          // 計算滑鼠相對於文字容器內部的 X 與 Y 座標
          const relX = e.clientX - rect.left;
          const relY = e.clientY - rect.top;

          // 檢查滑鼠當前是否位於文字容器的矩形範圍內
          const isHovering =
            e.clientX >= rect.left &&
            e.clientX <= rect.right &&
            e.clientY >= rect.top &&
            e.clientY <= rect.bottom;

          if (isHovering) {
            // 如果剛進入範圍，觸發類似 pointerenter 的放大效果
            if (!isInsideContainer) {
              isInsideContainer = true;
              radiusTo(circleRadius);
              gsap.to(pointerDot, {
                scale: 1,
                duration: 0.2,
                ease: "power2.out",
              });
            }

            // 持續更新遮罩與點點位置
            xTo(relX);
            yTo(relY);
          } else {
            // 如果滑鼠離開了文字容器的範圍，觸發類似 pointerleave 的縮小
            if (isInsideContainer) {
              isInsideContainer = false;
              radiusTo(0);
              gsap.to(pointerDot, {
                scale: 0,
                duration: 0.2,
                ease: "power2.in",
              });
            }
          }
        }

        // 當點擊畫面的任何地方（包括上方覆蓋的容器），只要在範圍內就放大遮罩
        function handleGlobalPointerDown(e: PointerEvent) {
          const rect = container!.getBoundingClientRect();
          const isHovering =
            e.clientX >= rect.left &&
            e.clientX <= rect.right &&
            e.clientY >= rect.top &&
            e.clientY <= rect.bottom;

          if (isHovering) {
            const relX = e.clientX - rect.left;
            const relY = e.clientY - rect.top;
            gsap.set(maskSettings, { x: relX, y: relY });
            radiusTo(circleRadius);
            gsap.to(pointerDot, {
              scale: 1,
              duration: 0.2,
              ease: "power2.out",
            });
          }
        }

        function handleGlobalPointerUp() {
          if (isInsideContainer) {
            radiusTo(0);
            gsap.to(pointerDot, { scale: 0, duration: 0.2, ease: "power2.in" });
          }
        }

        // 將事件改綁在全局 window，徹底無視上方圖層的遮擋
        window.addEventListener("pointermove", handleGlobalPointerMove);
        window.addEventListener("pointerdown", handleGlobalPointerDown);
        window.addEventListener("pointerup", handleGlobalPointerUp);
      }
    }
  }

  // 初始化函式：設定動畫並決定何時播放
  function setupTrigger() {
    initHeroAnimations();

    const hasOverlay = document.querySelector(".welcome-animation");
    console.log("Checking for welcome animation overlay:", hasOverlay);
    const isAnimationAlreadyFinished =
      (window as any).__welcomeFinished === true;
    console.log(
      "Is welcome animation already finished?",
      isAnimationAlreadyFinished,
    );

    if (!hasOverlay || isAnimationAlreadyFinished) {
      playHeroAnimations();
    } else {
      window.addEventListener("welcomeFinished", playHeroAnimations, {
        once: true,
      });
    }
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", setupTrigger);
  } else {
    setupTrigger();
  }
</script>
