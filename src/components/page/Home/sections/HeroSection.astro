---
import { getImage } from "astro:assets";
import AnimateTitle from "@/components/page/Home/compose/hero/AnimateTitle.astro";
import StatusBadge from "@/components/page/Home/compose/hero/StatusBadge.astro";
import { Button } from "@/components/ui/button.tsx";
import { ArrowRight, FolderBookmark, UsersRound, Gauge } from "lucide-react";
import { Image } from "astro:assets";

import CharacterImage from "@/assets/pages/home/misana-character_long.png";
import BGGrid from "@/assets/pages/home/dark_bg-grid.svg";
import RTBracket from "@/assets/pages/home/quote-right_top-brackets.svg";
import LBBracket from "@/assets/pages/home/quote-left_bottom-brackets.svg";

const optimizedImage = await getImage({ src: CharacterImage, width: 540 });
---

<section
  id="sh-hero-section"
  class="hero-section relative h-svh overflow-hidden rounded-b-3xl rounded-bl-3xl bg-white/7"
>
  <div class="relative flex h-full w-full items-center justify-center">
    <!-- 背景互動元件 -->
    <div
      class="absolute top-45 -z-10 h-[200px] w-[120%] rotate-20 bg-cover bg-center lg:rotate-0"
      aria-hidden="true"
    >
      <AnimateTitle />
    </div>

    <!-- 背景網格 -->
    <div
      class="absolute bottom-0 left-1/2 -z-20 -translate-x-1/2 opacity-60"
      aria-hidden="true"
    >
      <Image src={BGGrid} alt="背景網格" />
    </div>

    <!-- 立繪 -->
    <div
      class="absolute -bottom-6 left-0 flex h-full flex-col items-end justify-end lg:left-1/2 lg:-translate-x-1/2"
      id="sh-hero-tachie"
    >
      <div class="relative -mb-4 flex w-full items-center justify-center">
        <div class="w-10"></div>

        <StatusBadge class="hidden lg:flex" />
      </div>

      <img
        src={optimizedImage.src}
        alt="Hero Character"
        class="h-[90vh] w-auto max-w-none lg:h-[80vh]"
      />
    </div>

    <!-- 主框架 -->
    <div
      class="absolute bottom-0 left-1/2 flex w-full max-w-[1246px] -translate-x-1/2 items-end justify-between px-8 pb-16 lg:bottom-30 lg:bg-none! lg:pb-0 xl:items-start xl:px-0"
      id="sh-hero-mainframe"
    >
      <!-- 左區段 -->
      <div class="flex max-w-110 flex-col gap-5 lg:gap-15" id="sh-hero-mf-left">
        <div class="relative flex lg:-mb-10">
          <StatusBadge class="flex lg:hidden" />
        </div>

        <h1 class="text-6xl font-black text-stone-200 lg:text-[96px]/[120%]">
          Sam<br />Hacker
        </h1>

        <p class="text-lg text-stone-300">
          我是一個熱愛分享技術的高中生，<br />
          專注於 Minecraft 開服、網站建設、開源軟體等領域。<br />
          我的目標是讓更多人能夠輕鬆學習和應用技術。
        </p>

        <div class="flex gap-2.5">
          <a href="/about" aria-label="關於我按鈕的連結元件">
            <Button
              size="lg"
              variant="secondary"
              aria-label="關於我"
              className="font-regular h-auto px-[30px]! py-2.5 text-lg"
            >
              關於我
              <ArrowRight className="ml-2.5" />
            </Button>
          </a>

          <a href="/projects" aria-label="專案列表">
            <Button
              size="icon-hero"
              aria-label="專案列表"
              variant="ghost"
              className="h-full p-0"
            >
              <FolderBookmark size={24} className="size-5" />
            </Button>
          </a>

          <a href="/friends" aria-label="朋友列表">
            <Button
              size="icon-hero"
              aria-label="朋友"
              variant="ghost"
              className="h-full p-0"
            >
              <UsersRound size={24} className="size-5" />
            </Button>
          </a>

          <a href="/dashboard" aria-label="數據儀表板">
            <Button
              size="icon-hero"
              aria-label="數據儀表板"
              variant="ghost"
              className="h-full p-0"
            >
              <Gauge size={24} className="size-5" />
            </Button>
          </a>
        </div>
      </div>

      <!-- 右區段 -->
      <div
        class="relative mt-10 hidden max-h-[150px] min-h-[150px] w-full max-w-100 items-center justify-center lg:flex"
        id="sh-hero-mf-right"
      >
        <Image
          src={RTBracket}
          alt="右上括號"
          class="absolute top-0 right-0 opacity-50"
          id="sh-hero-mf-right-bracket"
        />
        <Image
          src={LBBracket}
          alt="左下括號"
          class="absolute bottom-0 left-0 opacity-50"
          id="sh-hero-mf-left-bracket"
        />

        <p
          class="text-center font-funny text-3xl text-stone-300"
          id="sh-hero-mf-quote"
        >
          正因為曾經淋過雨，<br />
          才會想為他人撐一把傘。
        </p>
      </div>
    </div>
  </div>
</section>

<style>
  #sh-hero-mainframe {
    background: #000;
    background: linear-gradient(
      180deg,
      rgba(0, 0, 0, 0) 0%,
      rgba(0, 0, 0, 1) 100%
    );
  }
</style>

<script>
  // Hero Section GSAP Animation
  import gsap from "gsap";
  import SplitText from "gsap/SplitText";
  import ScrollTrigger from "gsap/ScrollTrigger";

  gsap.registerPlugin(SplitText);
  gsap.registerPlugin(ScrollTrigger);

  // 跨函式傳遞 SplitText
  let titleSplitInstance: any = null;
  let quoteSplitInstance: any = null;
  let isInitialized = false;

  // 初始化函式
  function initHeroAnimations() {
    // 防止重複初始化（特別是在 Astro 切換頁面或重複觸發時）
    if (isInitialized) return;

    console.log(
      "🚀 Immediate Initialization: Hiding elements and splitting text...",
    );

    // 預設狀態：將所有動畫元素隱藏並稍微位移
    gsap.set("#sh-hero-tachie img", { y: 100, opacity: 0 });
    gsap.set("#sh-hero-mf-left > *:not(h1)", { y: 30, opacity: 0 });
    gsap.set("#sh-hero-mf-right", { y: 50, opacity: 0 });

    // 右容器中的括號
    gsap.set("#sh-hero-mf-right-bracket", { x: -70, y: 30, opacity: 0 });
    gsap.set("#sh-hero-mf-left-bracket", { x: 70, y: -30, opacity: 0 });

    // 標題的分割飛入動畫（立刻分割並隱藏，避免文字閃爍）
    titleSplitInstance = new SplitText("#sh-hero-mf-left h1", {
      type: "chars",
    });
    gsap.set(titleSplitInstance.chars, { y: 50, opacity: 0 });

    // 將右容器中的文字切分成單字
    quoteSplitInstance = new SplitText("#sh-hero-mf-quote", { type: "chars" });

    isInitialized = true;
  }

  // 播放時間軸
  function playHeroAnimations() {
    console.log("🎬 Starting hero timeline animations...");

    // 安全檢查：確保播放前一定有完成初始化
    if (!isInitialized || !titleSplitInstance || !quoteSplitInstance) {
      initHeroAnimations();
    }

    const tl = gsap.timeline({
      onComplete: beginParallaxScroll, // 動畫完成後啟用滾動事件監聽
      delay: 0.5,
    });

    tl.to(
      "#sh-hero-tachie img",
      { y: 0, opacity: 1, duration: 0.7, ease: "power2.out" },
      0.5,
    );

    tl.to(
      "#sh-hero-mf-left > *:not(h1)",
      { y: 0, opacity: 1, duration: 0.6, ease: "power2.out", stagger: 0.1 },
      0.8,
    ).to(
      titleSplitInstance.chars, // 使用初始化好的實例
      {
        y: 0,
        opacity: 1,
        duration: 1.2,
        ease: "power3.out",
        stagger: 0.05,
      },
      0.7,
    );

    tl.to(
      "#sh-hero-mf-right",
      { y: 0, opacity: 1, duration: 0.6, ease: "power2.out" },
      1.2,
    )
      .from(quoteSplitInstance.chars, {
        // 使用初始化好的實例
        duration: 1.2,
        opacity: 0,
        x: (index, target, targets) => {
          return index < targets.length / 2 ? -200 : 200;
        },
        rotation: (index, target, targets) => {
          return index < targets.length / 2 ? -15 : 15;
        },
        ease: "power3.out",
        stagger: {
          amount: 0.6,
          from: "edges",
        },
      })
      .to(
        "#sh-hero-mf-right-bracket",
        {
          x: 0,
          y: 0,
          opacity: 1,
          duration: 0.5,
          ease: "power2.out",
          delay: 0.2,
        },
        1.7,
      )
      .to(
        "#sh-hero-mf-left-bracket",
        {
          x: 0,
          y: 0,
          opacity: 1,
          duration: 0.5,
          ease: "power2.out",
          delay: 0.2,
        },
        1.7,
      );

    function beginParallaxScroll() {
      console.log("Parallax scroll enabled");
      ScrollTrigger.refresh();

      const parallaxTl = gsap.timeline({
        scrollTrigger: {
          trigger: "#sh-hero-section",
          start: "top top",
          end: "bottom top",
          scrub: true,
        },
      });

      parallaxTl.to(
        "#sh-hero-mf-left > *:not(h1)",
        { y: -150, duration: 0.8, ease: "none", stagger: 0.05 },
        0.1,
      );

      parallaxTl.to(
        titleSplitInstance.chars,
        {
          y: (index) => -220 - index * 20,
          duration: 0.9,
          ease: "none",
          stagger: 0.01,
        },
        0.1,
      );

      parallaxTl.to(
        "#sh-hero-mf-right",
        { y: -200, duration: 0.8, ease: "none" },
        0.2,
      );
      parallaxTl.to(
        "#sh-hero-tachie img",
        { y: -300, duration: 0.8, ease: "none" },
        0.05,
      );
    }
  }

  // 排程邏輯
  function setupTrigger() {
    initHeroAnimations();

    const hasOverlay = document.querySelector(".welcome-animation");
    console.log("Checking for welcome animation overlay:", hasOverlay);
    const isAnimationAlreadyFinished =
      (window as any).__welcomeFinished === true;
    console.log(
      "Is welcome animation already finished?",
      isAnimationAlreadyFinished,
    );

    if (!hasOverlay || isAnimationAlreadyFinished) {
      playHeroAnimations();
    } else {
      window.addEventListener("welcomeFinished", playHeroAnimations, {
        once: true,
      });
    }
  }

  function resetState() {
    isInitialized = false;
    titleSplitInstance = null;
    quoteSplitInstance = null;
    setupTrigger();
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", setupTrigger);
  } else {
    setupTrigger();
  }

  document.addEventListener("astro:page-load", resetState);
</script>
