---
import { Card, CardContent, CardHeader } from "@components/ui/card";
import { Info, MapPin, ThumbsUp, Phone, School, Share2 } from "@lucide/astro";
import { Github } from "simple-icons-astro";

import { Image } from "astro:assets";
import tcfshImage from "@/assets/pages/home/tcfsh-stroke.svg";

import { SkillCloud } from "@/components/page/Home/compose/self-intro/SkillCloud";
import { GitHubInfo } from "@/components/page/Home/compose/self-intro/GitHubInfo";
import SelfIntroLinkGridIcon from "@/components/page/Home/compose/self-intro/SelfIntroLinkGridIcon.astro";

import config from "@shConfig";
---

<div
  class="grid w-full grid-cols-1 gap-5 lg:max-w-none lg:grid-cols-4 lg:grid-rows-4"
>
  <!-- 自我介紹 -->
  <Card
    id="sh-about-description-card"
    className="group relative col-start-1 row-start-1 min-h-100 overflow-hidden shadow will-change-transform hover:bg-stone-800 lg:col-span-2 lg:row-span-2"
  >
    <!-- 背景裝飾 -->
    <div
      class="absolute -top-10 -left-10 h-60 w-60 rounded-full bg-gradient-to-tr from-purple-500 via-pink-500 to-red-500 opacity-20 blur-3xl transition-opacity duration-300 group-hover:opacity-0"
    >
    </div>
    <div class="absolute -bottom-4 left-0 flex w-full">
      <span
        class="sh-background-text-decoration w-full text-center text-8xl font-bold opacity-10 transition-opacity duration-300 select-none group-hover:opacity-20"
        >ABOUT</span
      >
    </div>

    <CardHeader
      id="sh-about-description-card-header"
      className="relative z-10 flex items-center gap-2 font-bold"
    >
      <Info size={20} stroke-width={3} />
      自我介紹
    </CardHeader>
    <CardContent
      id="sh-about-description-card-content"
      className="[&>p]:not-last-child:mb-4 relative z-10"
    >
      <p class="lead-8 mb-2">嗨！我是 SamHacker，一個熱愛 Coding 的高中生。</p>
      <p class="lead-8 mb-2">
        現年（2025 年）
        <span id="sh-intro-age" class="font-bold">:D</span>
        歲，善於運用 TypeScript、Python 等語言。<br />
        最近在學習 Next.js、Vite、React、GSAP 等框架，也計畫要涉獵 Svelte、Vue 等框架。
      </p>
      <p class="lead-8 mb-2">
        前端可能還算可以，但做後端就真的完全不行。
        說是這樣說啦，不過這也不代表我只會做網頁。不過C++看起來真的是天書......
      </p>
      <p class="lead-8">
        除了寫程式之外，我也喜歡玩遊戲、聽音樂和閱讀科技相關的文章。
        另外有些時候會去Penana之類的網站上寫一些文章，如果大家有興趣的話也可以去逛逛看。
      </p>
    </CardContent>
  </Card>

  <!-- 學校資訊 -->
  <Card
    id="sh-about-school-card"
    className="group relative col-span-1 min-h-50 overflow-hidden will-change-transform hover:bg-stone-800 lg:row-start-3"
  >
    <!-- 背景裝飾 -->
    <div
      class="absolute -top-10 -right-10 h-40 w-40 rounded-full bg-gradient-to-tr from-green-400 via-blue-500 to-purple-600 opacity-20 blur-3xl transition-opacity duration-300 group-hover:opacity-0"
    >
    </div>
    <div class="absolute -bottom-4 left-0 flex w-full justify-center">
      <Image
        src={tcfshImage}
        alt="台中一中大門線條圖"
        id="sh-about-school-bg-decoration"
        class="pointer-events-none mx-auto w-4/5 opacity-10 transition-opacity duration-300 select-none group-hover:opacity-20"
      />
    </div>

    <CardHeader className="relative z-10 flex items-center gap-2 font-bold">
      <School size={20} stroke-width={3} />
      學校
    </CardHeader>
    <CardContent className="relative z-10 flex items-center justify-center">
      <p>臺中市立臺中第一高級中學</p>
    </CardContent>
  </Card>

  <!-- GitHub資訊 -->
  <Card
    id="sh-about-github-card"
    className="relative col-span-1 min-h-50 overflow-hidden will-change-transform hover:bg-stone-800 lg:col-span-2 lg:row-start-4"
  >
    <CardContent className="relative z-10 flex gap-4">
      <GitHubInfo client:load />
    </CardContent>
  </Card>

  <!-- 聯絡資訊 -->
  <Card
    id="sh-about-contact-card"
    className="relative col-span-1 row-span-1 min-h-50 overflow-hidden will-change-transform hover:bg-stone-800 lg:col-start-2 lg:row-start-3"
  >
    <CardHeader className="relative z-10 flex items-center gap-2 font-bold">
      <Phone size={20} stroke-width={3} />聯絡我
    </CardHeader>
    <CardContent className="relative z-10">
      <p>
        電子郵件：<a
          href="mailto:xux510208@gmail.com"
          class="text-stone-400 hover:underline"
        >
          <br />
          xux510208@gmail.com
        </a>
      </p>
      <p>
        Discord：<br />
        <span class="mr-0 text-stone-600">
          @
          <a
            href="https://discordapp.com/users/959977374471028779"
            class="text-stone-400 hover:underline"
            >samhacker
          </a>
        </span>
      </p>
    </CardContent>
  </Card>

  <!-- 位置資訊 -->
  <Card
    id="sh-about-location-card"
    className="relative col-span-1 row-span-1 min-h-50 overflow-hidden will-change-transform hover:bg-stone-800 lg:col-start-3 lg:row-span-2 lg:row-start-3"
  >
    <canvas
      id="sh-about-location-cobe-canvas"
      class="pointer-events-none absolute -top-10 left-[85%] h-[300px] w-[300px] -translate-x-1/2 lg:top-1/2 lg:left-3/4 lg:h-[550px] lg:w-[550px] lg:-translate-x-1/4 lg:-translate-y-1/2"
    ></canvas>

    <CardHeader className="relative z-10 flex items-center gap-2 font-bold">
      <MapPin size={20} stroke-width={3} />臺中市，臺灣
    </CardHeader>
  </Card>

  <!-- 技能雲 -->
  <Card
    id="sh-about-skills-card"
    className="group relative col-span-1 row-span-1 min-h-50 overflow-hidden pb-0 shadow will-change-transform hover:bg-neutral-800 lg:col-span-2 lg:col-start-3 lg:row-span-2 lg:row-start-1"
  >
    <div
      class="absolute top-0 -right-25 flex h-full origin-center -rotate-90 items-center"
    >
      <span
        class="sh-background-text-decoration text-8xl font-bold opacity-10 transition-opacity duration-300 select-none group-hover:opacity-20"
      >
        SKILL
      </span>
    </div>

    <CardHeader className="relative z-10 flex items-center gap-2 font-bold">
      <ThumbsUp size={20} stroke-width={3} />我的能力
    </CardHeader>
    <CardContent
      id="sh-about-skills-card-content"
      className="relative z-10 min-h-40 flex-1 items-center justify-center"
    >
      <SkillCloud client:only="react" />
    </CardContent>
  </Card>

  <!-- 社群媒體 -->
  <Card
    id="sh-about-socials-card"
    className="relative col-span-1 min-h-50 overflow-hidden will-change-transform hover:bg-stone-800 lg:col-start-4 lg:row-span-2 lg:row-start-3"
  >
    <CardHeader className="relative z-10 flex items-center gap-2 font-bold">
      <Share2 size={20} stroke-width={3} />社群媒體
    </CardHeader>
    <CardContent
      className="relative z-10 grid grid-cols-4 gap-4 py-2 lg:grid-cols-3"
    >
      {
        config.socialLinks.map((link, index) => (
          <SelfIntroLinkGridIcon href={link.href} key={index}>
            <link.icon class="h-8 w-8" />
          </SelfIntroLinkGridIcon>
        ))
      }
    </CardContent>
  </Card>
</div>

<!-- 地球儀 -->
<script>
  import createGlobe from "cobe";

  let phi = 0;
  const DEFAULT_SPEED = 1 / 200;
  const HOVER_SPEED = 1 / 1000;

  let globeRotateSpeed = DEFAULT_SPEED;
  let canvas: HTMLCanvasElement;
  let animationFrameId: number | null = null;
  let targetSpeed = globeRotateSpeed;

  function smoothTransition() {
    const diff = targetSpeed - globeRotateSpeed;
    if (Math.abs(diff) > 0.0001) {
      globeRotateSpeed += diff * 0.05;
      animationFrameId = window.requestAnimationFrame(smoothTransition);
    } else {
      globeRotateSpeed = targetSpeed;
      animationFrameId = null;
    }
  }

  // 封裝初始化邏輯
  document.addEventListener("DOMContentLoaded", () => {
    canvas = document.getElementById(
      "sh-about-location-cobe-canvas",
    ) as HTMLCanvasElement;
    const card = document.getElementById("sh-about-location-card");

    if (!canvas || !card) return;

    // 動態獲取當前設備的像素比，若在手機上太消耗效能，可固定設為 2
    const dpr = window.devicePixelRatio || 2;

    // 獲取容器寬度（或設定固定的顯示寬度，例如 300px）
    // 這裡以 300 為基準，乘上 dpr 後繪製，再透過 CSS 縮小
    // const size = 300;

    const rect = canvas.getBoundingClientRect();
    const displaySize = rect.width || 300; // 電腦端會自動取得 550，手機端取得 300

    const globe = createGlobe(canvas, {
      devicePixelRatio: dpr,
      width: displaySize * dpr,
      height: displaySize * dpr,
      phi: 0,
      theta: 0,
      dark: 1,
      diffuse: 2,
      mapSamples: 16_000,
      mapBrightness: 2,
      baseColor: [0.8, 0.8, 0.8],
      markerColor: [1, 1, 1],
      glowColor: [0.5, 0.5, 0.5],
      markers: [
        { location: [24.110780463476758, 120.68685405275627], size: 0.1 },
      ],
      scale: 1.05,
      opacity: 0.9,
      onRender: (state) => {
        state.phi = phi;
        phi += globeRotateSpeed;
      },
    });

    card.addEventListener("mouseenter", () => {
      targetSpeed = HOVER_SPEED;
      if (animationFrameId) window.cancelAnimationFrame(animationFrameId);
      smoothTransition();
    });

    card.addEventListener("mouseleave", () => {
      targetSpeed = DEFAULT_SPEED;
      if (animationFrameId) window.cancelAnimationFrame(animationFrameId);
      smoothTransition();
    });

    return () => {
      globe.destroy(); // 卸載時銷毀實例，防止記憶體洩漏
    };
  });
</script>

<!-- 年齡計算 -->
<script>
  // 計算年齡
  document.addEventListener("DOMContentLoaded", () => {
    const birthDate = new Date("2008-05-15");
    const today = new Date();
    let age = today.getFullYear() - birthDate.getFullYear();
    const monthDiff = today.getMonth() - birthDate.getMonth();
    if (
      monthDiff < 0 ||
      (monthDiff === 0 && today.getDate() < birthDate.getDate())
    ) {
      age--;
    }
    // 更新年齡元素
    const ageElement = document.getElementById("sh-intro-age");
    if (ageElement) {
      ageElement.textContent = age.toString();
    }
  });
</script>

<!-- 動畫 -->
<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  import DrawSVG from "gsap/DrawSVGPlugin";

  gsap.registerPlugin(ScrollTrigger);
  gsap.registerPlugin(DrawSVG);

  document.addEventListener("DOMContentLoaded", () => {
    // 設定初始狀態
    const cards = [
      "#sh-about-description-card",
      "#sh-about-location-card",
      "#sh-about-skills-card",
      "#sh-about-github-card",
      "#sh-about-school-card",
      "#sh-about-contact-card",
      "#sh-about-socials-card",
    ];

    cards.forEach((card) => {
      gsap.set(card, {
        opacity: 0,
        y: 30,
        scale: 0.98,
        transformOrigin: "center",
      });
    });

    gsap.set("#sh-about-school-bg-decoration", {
      drawSVG: "0%",
      fillOpacity: 0,
    });

    // 創建動畫時間線
    const tl = gsap.timeline({
      scrollTrigger: {
        trigger: "#sh-intro-description",
        start: "top top+=50%",
        end: "bottom 25%",
        toggleActions: "play none none reverse",
      },
    });

    // 優化的動畫序列
    tl.to("#sh-about-description-card", {
      duration: 0.6,
      opacity: 1,
      y: 0,
      scale: 1,
      ease: "power2.out",
    })
      .to(
        "#sh-about-skills-card",
        {
          duration: 0.6,
          opacity: 1,
          y: 0,
          scale: 1,
          ease: "power2.out",
        },
        "-=0.2",
      )
      .to(
        "#sh-about-school-card",
        {
          duration: 0.6,
          opacity: 1,
          y: 0,
          scale: 1,
          ease: "power2.out",
        },
        "-=0.2",
      )
      .to(
        "#sh-about-contact-card",
        {
          duration: 0.6,
          opacity: 1,
          y: 0,
          scale: 1,
          ease: "power2.out",
        },
        "-=0.2",
      )
      .to(
        "#sh-about-github-card",
        {
          duration: 0.6,
          opacity: 1,
          y: 0,
          scale: 1,
          ease: "power2.out",
        },
        "-=0.2",
      )
      .to(
        "#sh-about-location-card",
        {
          duration: 0.6,
          opacity: 1,
          y: 0,
          scale: 1,
          ease: "power2.out",
        },
        "-=0.2",
      )
      .to(
        "#sh-about-socials-card",
        {
          duration: 0.6,
          opacity: 1,
          y: 0,
          scale: 1,
          ease: "power2.out",
        },
        "-=0.2",
      );

    // 動畫完成後清理 will-change
    tl.call(() => {
      cards.forEach((card) => {
        const element = document.querySelector(card) as HTMLElement;
        if (element) {
          element.style.willChange = "auto";
        }
      });
    });
  });
</script>
