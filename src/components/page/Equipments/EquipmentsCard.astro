---
import {
  Card,
  CardDescription,
  CardHeader,
  CardTitle,
} from "@/components/ui/card";
import { cn } from "@/lib/utils";
import type { ImageMetadata } from "astro";

import type { ShsiteConfig } from "@/types/shsite.config";

type EquipmentItem = ShsiteConfig["equipments"][number];

interface Props extends EquipmentItem {
  className?: string;
}

const { name, description, thumbnail, className = "" } = Astro.props;

const getImageUrl = (source: any): string | null => {
  if (typeof source === "string") return source;
  if (source && typeof source === "object" && "src" in source)
    return source.src;
  return null;
};

const imageUrl = getImageUrl(thumbnail);
---

<Card className={cn("sh-equipments-card bg-stone-900/40", className)}>
  <div class="align-center flex h-50 w-auto justify-center p-5">
    <img
      src={imageUrl}
      alt={name}
      class="h-[100%] max-h-50 w-auto max-w-50 object-contain"
    />
  </div>
  <CardHeader>
    <CardTitle className="text-inter text-lg">{name}</CardTitle>
    <CardDescription>{description}</CardDescription>
  </CardHeader>
</Card>
